<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network: downloading the JDK/SDK/Gradle bootstrap and resolving project dependencies. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage: reading/writing project files anywhere on device storage.
         Pre-Android 11 (API < 30): legacy runtime permissions, capped at API 29 by maxSdkVersion —
         Android 10 already has scoped storage as an opt-out via requestLegacyExternalStorage, and API 30+
         uses MANAGE_EXTERNAL_STORAGE below instead. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- Android 11+ (API 30+): "All files access" special permission, granted via Settings, needed
         because build tools and cloned repos must read/write anywhere the user picks, not just
         app-scoped storage. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Installing the debug/release APKs the on-device Gradle build produces. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <!-- Android 13+ (API 33+) runtime permission for the "build finished" notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Remote build keep-alive: elevates the process while the client streams a long server build
         so switching away is less likely to kill the WebSocket session. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 11+ package visibility: to auto-launch an app we just built + installed we must be
         able to resolve its MAIN/LAUNCHER activity. Without this, getLaunchIntentForPackage() is
         filtered to null and auto-launch silently no-ops. This narrow <queries> (launchable apps only)
         is the least-privilege grant — it avoids QUERY_ALL_PACKAGES and its Play-policy scrutiny. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".AslApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidStudioLite">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.AndroidStudioLite.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent trampoline: notification tap / resume → PackageInstaller confirm UI. -->
        <activity
            android:name="com.ahmadkharfan.androidstudiolite.data.buildsystem.install.InstallConfirmActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Elevates process priority while a remote build stream is active so backgrounding the
             IDE is less likely to kill the client mid-build. specialUse: long-running user-initiated
             build follow that fits no other FGS category. -->
        <service
            android:name="com.ahmadkharfan.androidstudiolite.feature.buildrun.RemoteBuildKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Following a user-initiated remote project build so progress and completion survive when the user leaves the IDE." />
        </service>
    </application>

</manifest>